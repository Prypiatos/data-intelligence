FROM python:3.11-slim

WORKDIR /app

COPY requirements.anomaly.txt .

RUN pip install --no-cache-dir -r requirements.anomaly.txt

COPY src/ ./src/
COPY models/ ./models/

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
