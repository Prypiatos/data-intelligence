# ============================================
# E2 Data Intelligence - Environment Variables
# ============================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=energy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/energy_db

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=energy_org
INFLUXDB_BUCKET=energy
INFLUXDB_TOKEN=your-influxdb-token

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=energy_forecasting

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Model Configuration
FORECAST_HORIZON_HOURS=24
BATCH_SIZE=32
EPOCHS=50
LEARNING_RATE=0.001
MODEL_TYPE=lstm

# Feature Engineering
WINDOW_SIZE_5MIN=5
WINDOW_SIZE_30MIN=30
WINDOW_SIZE_1HOUR=60
LAG_FEATURES_HOURS=24

# Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# Paths
DATA_DIR=/app/data
MODEL_DIR=/app/models
LOGS_DIR=/app/logs