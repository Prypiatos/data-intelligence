# ============================================
# E2 Data Intelligence - Environment Variables
# ============================================

# ============================================
# KAFKA Configuration
# ============================================
KAFKA_BROKER=kafka:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TELEMETRY=energy_telemetry
KAFKA_TOPIC_CLEAN_DATA=clean-telemetry
KAFKA_TOPIC_FORECASTS=energy_forecasts
KAFKA_TOPIC_ANOMALIES=energy_anomalies

# ============================================
# MQTT Configuration (Connection to E1)
# ============================================
MQTT_BROKER=mqtt-broker
MQTT_PORT=1883
MQTT_USERNAME=user
MQTT_PASSWORD=password
MQTT_TOPIC_TELEMETRY=energy/nodes/+/telemetry
MQTT_TOPIC_EVENTS=energy/nodes/+/events
MQTT_TOPIC_HEALTH=energy/nodes/+/health

# ============================================
# InfluxDB Configuration (Time-Series Storage)
# ============================================
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=energy_org
INFLUXDB_BUCKET=energy
INFLUXDB_TOKEN=your-influxdb-token-here
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpassword

# ============================================
# PostgreSQL Configuration (Relational Storage)
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=energy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/energy_db

# ============================================
# MLflow Configuration (Model Tracking)
# ============================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql://postgres:postgres@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_EXPERIMENT_NAME=energy_forecasting

# ============================================
# Apache Spark Configuration
# ============================================
SPARK_MASTER=spark://spark-master:7077
SPARK_HOME=/usr/local/spark
PYSPARK_PYTHON=python3

# ============================================
# Apache Flink Configuration
# ============================================
FLINK_JOBMANAGER_HOST=flink-jobmanager
FLINK_JOBMANAGER_PORT=6123
FLINK_TASKMANAGER_SLOTS=4

# ============================================
# Airflow Configuration
# ============================================
AIRFLOW_HOME=/home/airflow
AIRFLOW__CORE__DAGS_FOLDER=/home/airflow/dags
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql://postgres:postgres@postgres:5432/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_UID=50000

# ============================================
# Python / Application Configuration
# ============================================
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO
ENVIRONMENT=development

# ============================================
# Great Expectations Configuration
# ============================================
GE_CONTEXT_ROOT_DIR=/app/great_expectations
GE_CHECKPOINT_STORE_NAME=checkpoint_store

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# ============================================
# Data Paths
# ============================================
DATA_DIR=/app/data
MODEL_DIR=/app/models
LOGS_DIR=/app/logs

# ============================================
# Feature Engineering Configuration
# ============================================
WINDOW_SIZE_5MIN=5
WINDOW_SIZE_30MIN=30
WINDOW_SIZE_1HOUR=60
LAG_FEATURES_HOURS=24

# ============================================
# Model Configuration
# ============================================
FORECAST_HORIZON_HOURS=24
BATCH_SIZE=32
EPOCHS=50
LEARNING_RATE=0.001
MODEL_TYPE=lstm  # lstm or prophet

# ============================================
# Validation Configuration (Great Expectations)
# ============================================
VOLTAGE_MIN=200
VOLTAGE_MAX=240
CURRENT_MIN=0
CURRENT_MAX=100
POWER_FACTOR_MIN=0.8
POWER_FACTOR_MAX=1.0
FREQUENCY_MIN=49
FREQUENCY_MAX=51

# ============================================
# Email Configuration (For Alerts)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=team@company.com

# ============================================
# Redis Configuration (Caching)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# Testing Configuration
# ============================================
TEST_DATA_PATH=/app/tests/fixtures/energy-readings.json
MOCK_DATA_ENABLED=True
